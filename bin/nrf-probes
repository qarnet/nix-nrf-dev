#!/usr/bin/env python3
# SPDX-License-Identifier: MIT
#
# nrf-probes — identify which chip is attached to each CMSIS-DAP probe.
#
# Enumerates CMSIS-DAP probes from sysfs and fingerprints each target with a
# read-only OpenOCD session: DPIDR, AP IDR map, then FICR INFO.PART/VARIANT
# for the detected family. Never writes to the target.
#
# Usage:
#   nrf-probes                 # table of all probes and their targets
#   nrf-probes SERIAL [...]    # only these probe serials
#   nrf-probes --find nrf53    # print serial of the unique probe whose target
#                             # is an nRF53; exit 1 none / 2 ambiguous
#
# The probe<->board mapping must never be assumed from documentation: probes
# get replugged. This script is the source of truth.

import argparse
import subprocess
import sys
from pathlib import Path

USB_DEVICES = Path("/sys/bus/usb/devices")

PART_NAMES = {
    0x5340: "nRF5340",
    0x54B15: "nRF54L15",
    0x54B10: "nRF54L10",
    0x54B05: "nRF54L05",
    0x52840: "nRF52840",
    0x52833: "nRF52833",
    0x52832: "nRF52832",
    0x52820: "nRF52820",
    0x52811: "nRF52811",
    0x52810: "nRF52810",
    0x52805: "nRF52805",
}

# Read-only fingerprint proc. Family detection by DP/AP signature:
#   nRF53:  CTRL-APs at AP2/AP3 (IDR 0x12880000), FICR_S INFO at 0x00FF0200
#   nRF52:  DPv1 DPIDR 0x2ba01477, FICR at 0x10000000
#   nRF54L: DPIDR 0x6ba02477 without nRF53 CTRL-AP layout, FICR at 0x00FFC000
SCAN_TCL = r"""
proc fwp_scan {} {
    set dpidr ""
    catch {set dpidr [format 0x%08x [chip.dap dpreg 0]]}
    puts "FWP|dpidr|$dpidr"
    set ap {}
    for {set i 0} {$i < 4} {incr i} {
        set idr ""
        catch {set idr [format 0x%08x [chip.dap apreg $i 0xfc]]}
        lappend ap $idr
        puts "FWP|ap$i|$idr"
    }
    set family unknown
    set part_addr ""
    set var_addr ""
    if {[lindex $ap 2] eq "0x12880000"} {
        set family nrf53
        set part_addr 0x00FF020C
        set var_addr  0x00FF0210
    } elseif {$dpidr eq "0x2ba01477"} {
        set family nrf52
        set part_addr 0x10000100
        set var_addr  0x10000104
    } elseif {$dpidr eq "0x6ba02477"} {
        set family nrf54l
        catch {chip.dap apcsw 0x01000000 0x01000000}
        set part_addr 0x00FFC31C
        set var_addr  0x00FFC320
    }
    puts "FWP|family|$family"
    if {$part_addr ne ""} {
        set part ""
        set variant ""
        catch {set part [format 0x%08x [chip.cpu read_memory $part_addr 32 1]]}
        catch {set variant [format 0x%08x [chip.cpu read_memory $var_addr 32 1]]}
        puts "FWP|part|$part"
        puts "FWP|variant|$variant"
    }
}
"""


def enumerate_probes():
    """Yield (serial, product) for every USB device advertising CMSIS-DAP."""
    probes = []
    for dev in sorted(USB_DEVICES.glob("*")):
        try:
            product = (dev / "product").read_text().strip()
        except OSError:
            continue
        if "CMSIS-DAP" not in product:
            continue
        try:
            serial = (dev / "serial").read_text().strip()
        except OSError:
            continue
        probes.append((serial, product))
    return probes


def fingerprint(serial):
    cmd = [
        "openocd",
        "-f", "interface/cmsis-dap.cfg",
        "-c", f"adapter serial {serial}",
        "-c", "transport select swd",
        "-c", "adapter speed 1000",
        "-c", "gdb_port disabled",
        "-c", "tcl_port disabled",
        "-c", "telnet_port disabled",
        "-c", "swd newdap chip cpu",
        "-c", "dap create chip.dap -chain-position chip.cpu",
        "-c", "target create chip.cpu cortex_m -dap chip.dap",
        "-c", SCAN_TCL,
        "-c", "init",
        "-c", "fwp_scan",
        "-c", "shutdown",
    ]
    try:
        proc = subprocess.run(
            cmd, capture_output=True, text=True, timeout=30
        )
    except FileNotFoundError:
        sys.exit("nrf-probes: openocd not found on PATH — enter the dev shell first")
    except subprocess.TimeoutExpired:
        return {"note": "timeout talking to probe"}

    out = proc.stdout + proc.stderr
    info = {}
    for line in out.splitlines():
        if line.startswith("FWP|"):
            _, key, value = line.split("|", 2)
            info[key] = value
    if not info.get("dpidr"):
        if "unable to open CMSIS-DAP device" in out:
            info["note"] = "cannot open probe (udev permissions? probe in use?)"
        else:
            info["note"] = "no target (wiring? power?)"
    elif "Examination failed" in out and not info.get("part"):
        info["note"] = "AP locked (APPROTECT engaged) — identity from DP/AP signature only"
    return info


def chip_name(info):
    part = info.get("part", "")
    if part:
        try:
            return PART_NAMES.get(int(part, 16), f"nRF{int(part, 16):X}")
        except ValueError:
            pass
    family = info.get("family", "")
    if family and family != "unknown":
        return f"{family} (locked?)"
    if info.get("dpidr"):
        return "unknown target"
    return "-"


def variant_ascii(info):
    raw = info.get("variant", "")
    try:
        chars = bytes.fromhex(f"{int(raw, 16):08x}").decode("ascii")
        if chars.isalnum():
            return chars
    except (ValueError, UnicodeDecodeError):
        pass
    return raw or "-"


def main():
    parser = argparse.ArgumentParser(
        description="Identify chips attached to CMSIS-DAP probes (read-only)."
    )
    parser.add_argument("serials", nargs="*", help="probe serials (default: all)")
    parser.add_argument(
        "--find",
        metavar="FAMILY",
        help="print serial of the unique probe whose target matches FAMILY "
        "(nrf52/nrf53/nrf54l or a chip name like nRF5340)",
    )
    args = parser.parse_args()

    probes = enumerate_probes()
    if args.serials:
        probes = [p for p in probes if p[0] in args.serials]
        missing = set(args.serials) - {s for s, _ in probes}
        if missing:
            sys.exit(f"nrf-probes: no CMSIS-DAP probe with serial {', '.join(missing)}")
    if not probes:
        sys.exit("nrf-probes: no CMSIS-DAP probes found")

    results = [(serial, product, fingerprint(serial)) for serial, product in probes]

    if args.find:
        want = args.find.lower()
        matches = [
            serial
            for serial, _, info in results
            if want in (info.get("family", "").lower(), chip_name(info).lower())
        ]
        if len(matches) == 1:
            print(matches[0])
            return 0
        for serial, product, info in results:
            print(f"  {serial}  {product}  ->  {chip_name(info)}", file=sys.stderr)
        if not matches:
            print(f"nrf-probes: no probe with a {args.find} target", file=sys.stderr)
            return 1
        print(f"nrf-probes: multiple probes with a {args.find} target", file=sys.stderr)
        return 2

    header = ("SERIAL", "PROBE", "TARGET", "DPIDR", "PART", "VARIANT", "NOTE")
    rows = [header]
    for serial, product, info in results:
        rows.append(
            (
                serial,
                product,
                chip_name(info),
                info.get("dpidr", "-") or "-",
                info.get("part", "-") or "-",
                variant_ascii(info),
                info.get("note", ""),
            )
        )
    widths = [max(len(row[i]) for row in rows) for i in range(len(header))]
    for row in rows:
        print("  ".join(cell.ljust(w) for cell, w in zip(row, widths)).rstrip())
    return 0


if __name__ == "__main__":
    sys.exit(main())
